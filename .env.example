# Copy this file to `.env` for local development.
# The application reads provider secrets from environment variables.
#
# Notes:
# - `config/providers.yaml` decides which env var name is actually used via `api_key_env`.
# - `config/agent.yaml` can declare multi-channel instances via
#   `channels.instances[].app_id_env` / `app_secret_env`.

# LLM providers
# Current default primary provider in `config/agent.yaml` is `qwen`.
# In the current `config/providers.yaml`, qwen still reads from `OPENAI_API_KEY`,
# so put your DashScope-compatible key here when using the default config.
OPENAI_API_KEY=your-openai-or-dashscope-compatible-api-key

# Optional providers from `config/providers.yaml`
ANTHROPIC_API_KEY=your-anthropic-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# Single Feishu bot example
# Used when you run the default single-channel mode.
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Multi-Feishu channel examples
# Used when `config/agent.yaml` declares `channels.instances`, for example:
#   - name: feishu-main
#     app_id_env: FEISHU_MAIN_APP_ID
#     app_secret_env: FEISHU_MAIN_APP_SECRET
#   - name: feishu-ops
#     app_id_env: FEISHU_OPS_APP_ID
#     app_secret_env: FEISHU_OPS_APP_SECRET
#   - name: feishu-sales
#     app_id_env: FEISHU_SALES_APP_ID
#     app_secret_env: FEISHU_SALES_APP_SECRET
FEISHU_MAIN_APP_ID=cli_xxxxxxxxx_main
FEISHU_MAIN_APP_SECRET=xxxxxxxxxxxxxxxx_main
FEISHU_OPS_APP_ID=cli_xxxxxxxxx_ops
FEISHU_OPS_APP_SECRET=xxxxxxxxxxxxxxxx_ops
FEISHU_SALES_APP_ID=cli_xxxxxxxxx_sales
FEISHU_SALES_APP_SECRET=xxxxxxxxxxxxxxxx_sales

DEEPSEEK_API_KEY=xxxx
