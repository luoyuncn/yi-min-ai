# Copy this file to `.env` for local development.
# The application reads provider secrets from environment variables.
#
# Notes:
# - `config/providers.yaml` decides which env var name is actually used via `api_key_env`.
# - `config/agent.yaml` can declare multi-channel instances via
#   `channels.instances[].app_id_env` / `app_secret_env`.

# LLM providers
# Current default primary provider in `config/agent.yaml` is `qwen`.
# In the current `config/providers.yaml`, qwen still reads from `OPENAI_API_KEY`,
# so put your DashScope-compatible key here when using the default config.
OPENAI_API_KEY=your-openai-or-dashscope-compatible-api-key

# Optional providers from `config/providers.yaml`
ANTHROPIC_API_KEY=your-anthropic-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# Feishu bot
# The default runtime is one Feishu channel backed by one Yi Min subject.
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
